# Python
__pycache__/
*.py[cod]
*.pyc
.env
venv/
.venv/

# Terraform state (sensitive)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Excel temp files
~$*.xlsx
~$*.xls
.~lock.*#

# Browser cache artifacts (from viewing files in Office/Excel Online)
*.js.download
*_files/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets — never commit these
*.pem
*.key
secrets.json
.env.local

# Large PDF source files — stored in SharePoint, not Git
Delivery Notes/
*.pdf

# OCR temp files
*.ppm
